# Profitly environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real secrets.

# --- Supabase ---
# Find these in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Claude API for AI categorization) ---
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Sentry error monitoring ---
# Create a project at https://sentry.io/ and paste the DSN into both vars.
# Same value in both — NEXT_PUBLIC_ is exposed to the browser bundle,
# SENTRY_DSN is used on the server. Leave blank to disable Sentry locally.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
